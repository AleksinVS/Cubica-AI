{
  "name": "@cubica/runtime-api",
  "version": "0.0.0",
  "private": true,
  "description": "Modular monolith backend for Cubica runtime API.",
  "type": "module",
  "dependencies": {
    "@cubica/contracts-manifest": "file:../../packages/contracts/manifest",
    "@cubica/contracts-runtime": "file:../../packages/contracts/runtime",
    "@cubica/contracts-session": "file:../../packages/contracts/session",
    "ajv": "^8.20.0",
