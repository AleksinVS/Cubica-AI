{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.local/schemas/external-skill-policy.schema.json",
  "title": "Cubica External Skill Compatibility Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "policyVersion", "adapterVersion", "sources", "rules", "checks"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "policyVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "adapterVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "heading", "normalizedSha256"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
          "path": { "type": "string", "minLength": 1 },
          "heading": { "type": "string", "minLength": 1 },
          "normalizedSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "tags", "statement", "remediation", "sourceIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
          "severity": { "enum": ["block", "review", "guidance"] },
          "tags": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "statement": { "type": "string", "minLength": 1 },
          "remediation": { "type": "string", "minLength": 1 },
          "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbiddenActivePatterns", "signalPatterns"],
      "properties": {
        "forbiddenActivePatterns": { "type": "array", "items": { "type": "string" } },
        "signalPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "pattern", "tags"],
            "properties": {
              "id": { "type": "string" },
              "pattern": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
            }
          }
        }
      }
    }
  }
}
