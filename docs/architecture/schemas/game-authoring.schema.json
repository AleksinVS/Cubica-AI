{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.platform/schemas/game-authoring.v1.json",
  "title": "Cubica Game Authoring Manifest",
  "description": "Editable source format for game manifests. It compiles into game.manifest.json and is not consumed by runtime-api.",
  "type": "object",
  "required": [
    "_schemaVersion",
    "_manifestType",
    "_definitions",
    "root"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_schemaVersion": {
      "const": "1.0"
    },
    "_manifestType": {
      "const": "game"
    },
    "_definitions": {
      "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/definitionsMap"
    },
    "root": {
      "type": "object",
      "description": "Authoring root that resolves into the runtime game manifest.",
      "properties": {
        "objectTypes": {
          "$ref": "#/definitions/gameObjectTypeMap"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "definitions": {
    "gameObjectFacet": {
      "type": "object",
      "required": [
        "initial",
        "values"
      ],
      "properties": {
        "initial": {
          "$ref": "#/definitions/gameObjectFacetValue"
        },
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/gameObjectFacetValueDefinition"
          }
        }
      },
      "additionalProperties": false
    },
    "gameObjectFacetValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "gameObjectFacetValueDefinition": {
      "type": "object",
      "properties": {
        "interactive": {
          "type": "boolean"
        },
        "view": {
          "$ref": "#/definitions/gameObjectViewRule"
        },
        "visible": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "gameObjectType": {
      "type": "object",
      "required": [
        "collection",
        "scope",
        "facets"
      ],
      "properties": {
        "collection": {
          "type": "string"
        },
        "facets": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/gameObjectFacet"
          }
        },
        "idField": {
          "type": "string"
        },
        "scope": {
          "enum": [
            "session",
            "player"
          ],
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "gameObjectTypeMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/gameObjectType"
      }
    },
    "gameObjectViewRule": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "interactive": {
          "type": "boolean"
        },
        "selectLabelFrom": {
          "type": "string"
        },
        "summaryFrom": {
          "type": "string"
        },
        "textFrom": {
          "type": "string"
        },
        "titleFrom": {
          "type": "string"
        },
        "visible": {
          "type": "boolean"
        },
        "visualState": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
