{
  "$schema": "https://cubica.platform/schemas/game-authoring.v2.json",
  "_schemaVersion": "2.0",
  "_manifestType": "game",
  "_definitions": {
    "game.ChoiceCardPrototype": {
      "_semantics": "Переиспользуемый прототип карточного решения для проверки _promptTemplate.",
      "_label": "Прототип карточного решения",
      "_promptTemplate": {
        "raw": "Опишите карточку решения: лицевую сторону, оборотную сторону, действие при выборе, изменения метрик и методический смысл.",
        "language": "ru",
        "appliesTo": "game.ChoiceCardPrototype"
      }
    }
  },
  "root": {
    "_type": "game.Game",
    "_label": "Минимальная игра v2",
    "_semantics": "Минимальный game authoring v2 пример для проверки структуры логики и компилятора.",
    "meta": {
      "id": "authoring-v2-fixture",
      "version": "1.0.0",
      "name": "Authoring V2 Fixture",
      "description": "Minimal game authoring v2 fixture.",
      "author": "Cubica",
      "schemaVersion": "1.1",
      "minEngineVersion": "0.1.0",
      "training": {
        "format": "single"
      }
    },
    "config": {
      "players": {
        "min": 1,
        "max": 1
      },
      "settings": {
        "mode": "singleplayer",
        "locale": "ru-RU"
      }
    },
    "logic": {
      "entry": "opening",
      "flows": [
        {
          "id": "opening",
          "_type": "game.Flow",
          "_label": "Открывающая цепочка",
          "_semantics": "Линейный сценарный поток, из которого строится timeline редактора.",
          "pattern": "pearl-string",
          "steps": [
            {
              "id": "opening.intro",
              "_type": "game.Step",
              "_label": "Вступление",
              "_semantics": "Первый шаг прохождения, связанный с начальным экраном.",
              "_requiresView": true,
              "screenId": "intro",
              "actionIds": [
                "choice.accept"
              ]
            }
          ]
        }
      ],
      "systems": [],
      "rules": [],
      "actions": [
        {
          "id": "choice.accept",
          "_type": "game.Action",
          "_label": "Принять решение",
          "_semantics": "Действие игрока, доступное на начальном экране.",
          "_prompt": {
            "status": "confirmed",
            "raw": "Это универсальная карточка решения. На лицевой стороне коротко показан выбор игрока. При выборе карточки игра фиксирует решение и увеличивает счет на 1.",
            "normalized": "Создать универсальную карточку решения. Лицевая сторона кратко показывает выбор игрока. При выборе карточки нужно выполнить действие choice.accept и увеличить метрику score на 1.",
            "source": "user",
            "language": "ru",
            "updatedAt": "2026-06-12T00:00:00Z"
          },
          "capabilityFamily": "runtime.server",
          "capability": "authoring-v2.choice.accept",
          "displayName": "Accept the choice",
          "description": "Minimal action emitted from authoring v2 into the runtime action map.",
          "binding": {
            "kind": "mechanics-plan",
            "planRef": "choice.accept"
          }
        }
      ]
    },
    "state": {
      "public": {
        "timeline": {
          "flowId": "opening",
          "stepId": "opening.intro",
          "screenId": "intro"
        },
        "metrics": {
          "score": 0
