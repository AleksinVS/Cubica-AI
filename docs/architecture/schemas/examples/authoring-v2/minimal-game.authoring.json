{
  "$schema": "https://cubica.platform/schemas/game-authoring.v2.json",
  "_schemaVersion": "2.0",
  "_manifestType": "game",
  "_definitions": {},
  "root": {
    "_type": "game.Game",
    "_label": "Минимальная игра v2",
    "_semantics": "Минимальный game authoring v2 пример для проверки структуры логики и компилятора.",
    "meta": {
      "id": "authoring-v2-fixture",
      "version": "1.0.0",
      "name": "Authoring V2 Fixture",
      "description": "Minimal game authoring v2 fixture.",
      "author": "Cubica",
      "schemaVersion": "1.1",
      "minEngineVersion": "0.1.0",
      "training": {
        "format": "single"
      }
    },
    "config": {
      "players": {
        "min": 1,
        "max": 1
      },
      "settings": {
        "mode": "singleplayer",
        "locale": "ru-RU"
      }
    },
    "logic": {
      "entry": "opening",
      "flows": [
        {
          "id": "opening",
          "_type": "game.Flow",
          "_label": "Открывающая цепочка",
