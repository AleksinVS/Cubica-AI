      "plans": {
        "choice.accept": {
          "transaction": {
            "steps": [
              {
                "id": "available",
                "kind": "assert",
                "op": "core.assert",
                "predicate": {
                  "op": "predicate.constant",
                  "value": true
                },
                "errorCode": "ACTION_PRECONDITION_FAILED"
              }
            ]
          }
        }
      }
    }
