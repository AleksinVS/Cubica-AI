{
  "$schema": "../../plugin.schema.json",
  "id": "antarctica-player",
  "gameId": "antarctica",
  "apiVersion": "2.0",
  "targets": {
    "player-web": {
      "entry": "src/index.ts",
      "contributes": {
        "gameConfigFactory": true
      }
    }
  },
  "validation": {
    "typecheck": "typecheck"
  },
  "permissions": {
    "network": false,
    "filesystem": "plugin-root-only",
    "environment": []
  },
  "dependenciesPolicy": "platform-only"
}
