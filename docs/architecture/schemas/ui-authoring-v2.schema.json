{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.platform/schemas/ui-authoring.v2.json",
  "title": "Cubica UI Authoring Manifest V2",
  "description": "Editable v2 source format for UI authoring manifests. V2 stores screens and components as a semantic tree under root.",
  "type": "object",
  "required": [
    "_schemaVersion",
    "_manifestType",
    "_channel",
    "_definitions",
    "root"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_schemaVersion": {
      "const": "2.0"
    },
    "_manifestType": {
      "const": "ui"
    },
    "_channel": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Delivery channel compiled by this authoring file, for example web or telegram."
    },
    "_definitions": {
      "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/definitionsMap"
    },
    "root": {
      "$ref": "#/definitions/uiRoot"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "uiRoot": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "meta",
            "entry_point",
            "screens"
          ],
          "properties": {
            "meta": {
              "$ref": "#/definitions/uiMeta"
            },
            "entry_point": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "default_layout_mode": {
              "type": "string",
              "enum": ["leftsidebar", "topbar", "map-first", "auto"],
              "description": "Design-time layout the game presents for this channel (ADR-093). The compiler passes it through to ui.manifest.json.default_layout_mode unchanged. Screen routing matches conditions.layoutMode against this value instead of server-side UI state."
            },
            "theme": {
              "type": "object"
            },
            "stylesheets": {
              "type": "array",
              "description": "Optional game-owned CSS assets for this channel (ADR-091). Authors list stylesheet asset references as asset:<id>; the compiler passes them through to ui.manifest.json.stylesheets unchanged (compiler pass-through is delivered in TSK-20260719 block R3).",
              "items": {
                "type": "string",
                "pattern": "^asset:[a-z0-9][a-z0-9-]{0,63}$"
              },
              "uniqueItems": true
            },
            "screens": {
              "type": "array",
              "description": "Authoring screen entities. The compiler emits a runtime screens map keyed by screen id.",
              "items": {
                "$ref": "#/definitions/uiScreen"
              }
            },
            "design_artifacts": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "uiMeta": {
      "type": "object",
      "description": "Runtime-facing UI metadata.",
      "required": [
        "id",
        "version",
        "game_id"
      ],
      "properties": {
        "id": {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
        },
        "version": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "min_viewer_version": {
          "type": "string"
        },
        "game_id": {
          "type": "string"
        },
        "game_manifest_version": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        },
        "author": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "uiScreen": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "id",
            "root"
          ],
          "properties": {
            "id": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "title": {
              "type": "string"
            },
            "layout_mode": {
              "type": "string",
              "enum": ["leftsidebar", "topbar", "map-first", "auto"]
            },
            "layout_id": {
              "type": "string"
            },
            "design_artifact_id": {
              "type": "string"
            },
            "controller_id": {
              "type": "string"
            },
            "root": {
              "$ref": "#/definitions/uiComponent"
            }
          },
          "additionalProperties": true,
          "allOf": [
            {
              "if": {
                "properties": {
                  "layout_mode": { "const": "map-first" }
                },
                "required": ["layout_mode"]
              },
              "then": {
                "properties": {
                  "root": {
                    "type": "object",
                    "required": ["type", "children"],
                    "properties": {
                      "type": { "const": "screenComponent" },
                      "children": {
                        "type": "array",
                        "minItems": 1,
                        "items": { "$ref": "#/definitions/mapFirstWorkspaceZone" },
                        "contains": {
                          "type": "object",
                          "required": ["type", "props"],
                          "properties": {
                            "type": { "const": "areaComponent" },
                            "props": {
                              "type": "object",
                              "required": ["workspaceSlot"],
                              "properties": {
                                "workspaceSlot": { "const": "board" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "else": {
                "properties": {
                  "root": {
                    "not": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
                  }
                }
              }
            }
          ]
        }
      ]
    },
    "workspaceSlot": {
      "type": "string",
      "description": "Semantic placement owned by the generic map-first workspace.",
      "enum": [
        "board",
        "status",
        "primary-panel",
        "context-panel",
        "action-tray",
        "floating-controls",
        "overlay"
      ]
    },
    "componentTreeContainsWorkspaceSlot": {
      "description": "Recursive detector used to forbid workspaceSlot outside direct map-first zones.",
      "anyOf": [
        {
          "type": "object",
          "required": ["props"],
          "properties": {
            "props": {
              "type": "object",
              "required": ["workspaceSlot"]
            }
          }
        },
        {
          "type": "object",
          "required": ["children"],
          "properties": {
            "children": {
              "type": "array",
              "contains": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
            }
          }
        }
      ]
    },
    "mapFirstWorkspaceZone": {
      "type": "object",
      "description": "A direct child of a map-first screen root. Nested components cannot declare another workspace zone.",
      "required": ["type", "props"],
      "properties": {
        "type": { "const": "areaComponent" },
        "props": {
          "type": "object",
          "required": ["workspaceSlot"],
          "properties": {
            "workspaceSlot": { "$ref": "#/definitions/workspaceSlot" }
          }
        },
        "children": {
          "type": "array",
          "items": {
            "not": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
          }
        }
      }
    },
    "uiComponent": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "id": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "type": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_:-]*$"
            },
            "if": {
              "type": "string"
            },
            "props": {
              "type": "object",
              "properties": {
                "workspaceSlot": { "$ref": "#/definitions/workspaceSlot" }
              }
            },
            "style": {
              "type": "object"
            },
            "actions": {
              "type": "object"
            },
            "layout_id": {
              "type": "string"
            },
            "design_artifact_id": {
              "type": "string"
            },
            "controller_id": {
              "type": "string"
            },
            "children": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/uiComponent"
              }
            }
          },
          "additionalProperties": true,
          "allOf": [
            {
              "if": {
                "required": ["props"],
                "properties": {
                  "props": {
                    "type": "object",
                    "required": ["workspaceSlot"]
                  }
                }
              },
              "then": {
                "properties": {
                  "type": { "const": "areaComponent" }
                }
              }
            }
          ]
        }
      ]
    }
  }
}
