{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.platform/schemas/ui-authoring.v2.json",
  "title": "Cubica UI Authoring Manifest V2",
  "description": "Editable v2 source format for UI authoring manifests. V2 stores screens and components as a semantic tree under root.",
  "type": "object",
  "required": [
    "_schemaVersion",
    "_manifestType",
    "_channel",
    "_definitions",
    "root"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_schemaVersion": {
      "const": "2.0"
    },
    "_manifestType": {
      "const": "ui"
    },
    "_channel": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Delivery channel compiled by this authoring file, for example web or telegram."
    },
    "_definitions": {
      "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/definitionsMap"
    },
    "root": {
      "$ref": "#/definitions/uiRoot"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "uiRoot": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "meta",
            "entry_point",
            "screens"
          ],
          "properties": {
            "meta": {
              "$ref": "#/definitions/uiMeta"
            },
            "entry_point": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "theme": {
              "type": "object"
            },
            "screens": {
              "type": "array",
              "description": "Authoring screen entities. The compiler emits a runtime screens map keyed by screen id.",
              "items": {
                "$ref": "#/definitions/uiScreen"
              }
            },
            "design_artifacts": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "uiMeta": {
      "type": "object",
      "description": "Runtime-facing UI metadata.",
      "required": [
        "id",
        "version",
        "game_id"
      ],
      "properties": {
        "id": {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
        },
        "version": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "min_viewer_version": {
          "type": "string"
        },
        "game_id": {
          "type": "string"
        },
        "game_manifest_version": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        },
        "author": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "uiScreen": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "id",
            "root"
          ],
          "properties": {
            "id": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "title": {
              "type": "string"
            },
            "layout_mode": {
              "type": "string"
            },
            "layout_id": {
              "type": "string"
            },
            "design_artifact_id": {
              "type": "string"
            },
            "controller_id": {
              "type": "string"
            },
            "root": {
              "$ref": "#/definitions/uiComponent"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "uiComponent": {
      "allOf": [
        {
          "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/semanticEntity"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "id": {
              "$ref": "https://cubica.platform/schemas/manifest-authoring-common.schema.json#/definitions/entityId"
            },
            "type": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_:-]*$"
            },
            "if": {
              "type": "string"
            },
            "props": {
              "type": "object"
            },
            "style": {
              "type": "object"
            },
            "actions": {
              "type": "object"
            },
            "layout_id": {
              "type": "string"
            },
            "design_artifact_id": {
              "type": "string"
            },
            "controller_id": {
              "type": "string"
            },
            "children": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/uiComponent"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
