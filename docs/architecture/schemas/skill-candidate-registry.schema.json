{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.local/schemas/skill-candidate-registry.schema.json",
  "title": "Cubica Inactive Skill Candidate Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "cadenceDays", "candidates"],
  "properties": {
    "$schema": {
      "const": "https://cubica.local/schemas/skill-candidate-registry.schema.json"
    },
    "schemaVersion": { "const": "1.0" },
    "cadenceDays": { "type": "integer", "minimum": 1 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "sourceRepository", "sourceCommit", "upstreamPath",
          "importedPath", "license", "status", "activation", "importedAt",
          "files"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
          "sourceRepository": { "type": "string", "format": "uri" },
          "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "upstreamPath": { "type": "string", "minLength": 1 },
          "importedPath": { "type": "string", "pattern": "^skill-candidates/[^/]+/[^/]+$" },
          "license": { "type": "string", "minLength": 1 },
          "status": { "enum": ["reference-only", "adaptation-pending", "rejected"] },
          "activation": { "const": "forbidden" },
          "upstreamState": { "enum": ["current", "removed-upstream"] },
          "removalCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "importedAt": { "type": "string", "format": "date-time" },
          "notes": { "type": "string" },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          }
        }
      }
    }
  }
}
