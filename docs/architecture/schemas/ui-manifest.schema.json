{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.platform/schemas/ui-manifest.v1.json",
  "title": "Cubica UI Manifest",
  "description": "Schema for Cubica UI Manifests describing screens, components and layouts for Hybrid SDUI.",
  "type": "object",
  "required": ["meta", "screens", "entry_point"],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Метаданные UI-манифеста: идентификатор, версии и связь с игровым манифестом.",
      "required": ["id", "version", "game_id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Уникальный идентификатор UI-манифеста (может включать namespace игры и канала).",
          "pattern": "^[a-zA-Z0-9_.:-]+$"
        },
        "version": {
          "type": "string",
          "description": "Семантическая версия UI-манифеста.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "schema_version": {
          "type": "string",
          "description": "Версия схемы UI-манифеста (например, '1.0'). Обязательное поле для совместимости.",
          "pattern": "^\\d+\\.\\d+$"
        },
        "min_viewer_version": {
          "type": "string",
          "description": "Минимальная версия Viewer, необходимая для корректного отображения этого UI-манифеста.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "game_id": {
          "type": "string",
          "description": "Идентификатор целевого игрового манифеста (meta.id)."
        },
        "game_manifest_version": {
          "type": "string",
          "description": "Версия игрового манифеста, для которой разработан этот UI-манифест."
        },
        "channel": {
          "type": "string",
          "description": "Опциональный идентификатор канала (например, 'web', 'telegram')."
        },
        "author": {
          "type": "string",
          "description": "Автор UI-манифеста."
        }
      },
      "additionalProperties": false
    },
    "theme": {
      "type": "object",
      "description": "Optional global theme configuration (colors, typography, etc.).",
      "properties": {
        "colors": { "type": "object" },
        "typography": { "type": "object" }
      },
      "additionalProperties": true
    },
    "screens": {
      "type": "object",
      "description": "Registry of UI screens for this UI manifest.",
      "patternProperties": {
        "^[a-zA-Z0-9_.:-]+$": {
          "type": "object",
          "required": ["root"],
          "properties": {
            "type": { "const": "screen" },
            "title": { "type": "string" },
            "layout_mode": {
              "type": "string",
              "enum": ["leftsidebar", "topbar", "map-first", "auto"],
              "description": "Runtime layout selected by the player presenter. map-first makes one spatial board the full-screen workspace and places semantic UI zones above it."
            },
            "layout_id": {
              "type": "string",
              "description": "Optional reference to a design layout defined in the 'layouts' section. DEPRECATED: Use design_artifact_id."
            },
            "design_artifact_id": {
              "type": "string",
              "description": "ID дизайн-артефакта из секции design_artifacts.registry, описывающего визуальный дизайн этого экрана."
            },
            "controller_id": {
              "type": "string",
              "description": "Optional identifier of a UI-level controller in the UI library."
            },
            "root": {
              "$ref": "#/definitions/uiComponent"
            }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "layout_mode": { "const": "map-first" }
                },
                "required": ["layout_mode"]
              },
              "then": {
                "properties": {
                  "root": {
                    "type": "object",
                    "required": ["type", "children"],
                    "properties": {
                      "type": { "const": "screenComponent" },
                      "children": {
                        "type": "array",
                        "minItems": 1,
                        "items": { "$ref": "#/definitions/mapFirstWorkspaceZone" },
                        "contains": {
                          "type": "object",
                          "required": ["type", "props"],
                          "properties": {
                            "type": { "const": "areaComponent" },
                            "props": {
                              "type": "object",
                              "required": ["workspaceSlot"],
                              "properties": {
                                "workspaceSlot": { "const": "board" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "else": {
                "properties": {
                  "root": {
                    "not": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
                  }
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "panels": {
      "type": "object",
      "description": "Registry of transient UI panels such as journals, hints, inventory or help overlays. Panels are not scenario screens and do not participate in timeline routing.",
      "patternProperties": {
        "^[a-zA-Z0-9_.:-]+$": {
          "$ref": "#/definitions/uiPanel"
        }
      },
      "additionalProperties": false
    },
    "entry_point": {
      "type": "string",
      "description": "Identifier of the start screen to render (must exist in 'screens')."
    },
    "layouts": {
      "type": "object",
      "description": "Optional design layouts that link visual mockups and structured layout descriptions to screens or components. DEPRECATED: Prefer design_artifacts for new projects (see ADR-016).",
      "patternProperties": {
        "^[a-zA-Z0-9_.:-]+$": {
          "type": "object",
          "required": ["target", "image", "spec"],
          "properties": {
            "target": {
              "type": "object",
              "required": ["kind", "id"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["screen", "component"],
                  "description": "Whether this layout targets a whole screen or a specific component."
                },
                "id": {
                  "type": "string",
                  "description": "Identifier of the target screen or component."
                }
              },
              "additionalProperties": false
            },
            "image": {
              "type": "string",
              "description": "Path or URL to the layout image (export from design tool)."
            },
            "spec": {
              "type": "object",
              "description": "Free-form JSON description of the layout (grid, zones, annotations, etc.)."
            },
            "variant": {
              "type": "string",
              "description": "Optional variant identifier (e.g. 'desktop', 'mobile')."
            },
            "meta": {
              "type": "object",
              "description": "Optional metadata (author, timestamps, comments)."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "design_artifacts": {
      "type": "object",
      "description": "Реестр дизайн-артефактов для работы ИИ-агентов. Содержит ссылки на внешние JSON-описания изображений (reference, concept, flowchart, wireframe, storyboard, mockup, asset) с семантической разметкой и дизайн-токенами. См. ADR-016.",
      "properties": {
        "history": {
          "type": "string",
          "description": "Путь к файлу design-history.json с историей версий и графом связей артефактов."
        },
        "base_path": {
          "type": "string",
          "description": "Базовый путь к каталогу design/, относительно которого указаны пути в registry.",
          "default": "design/"
        },
        "registry": {
          "type": "object",
          "description": "Реестр артефактов. Ключ — ID артефакта, значение — ссылка на описание и связь с UI.",
          "additionalProperties": {
            "$ref": "#/definitions/designArtifactRef"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "uiPanel": {
      "type": "object",
      "required": ["mode", "root"],
      "properties": {
        "type": { "const": "panel" },
        "title": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["overlay", "drawer", "inline"],
          "description": "How the panel is presented relative to the current screen."
        },
        "layout_mode": {
          "type": "string",
          "enum": ["leftsidebar", "topbar", "map-first", "auto"],
          "description": "Runtime layout selected by the player presenter. Workspace slots remain screen-only and are not valid inside transient panels."
        },
        "layout_id": {
          "type": "string",
          "description": "Optional reference to a design layout defined in the 'layouts' section. DEPRECATED: Use design_artifact_id."
        },
        "design_artifact_id": {
          "type": "string",
          "description": "ID дизайн-артефакта из секции design_artifacts.registry, описывающего визуальный дизайн этой панели."
        },
        "controller_id": {
          "type": "string",
          "description": "Optional identifier of a UI-level controller in the UI library."
        },
        "root": {
          "$ref": "#/definitions/uiComponent"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "properties": {
            "root": {
              "not": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
            }
          }
        }
      ]
    },
    "uiComponentType": {
      "type": "string",
      "description": "Стандартные типы UI-компонентов платформы Cubica. Viewer должен поддерживать все перечисленные типы.",
      "enum": [
        "screenComponent",
        "areaComponent",
        "cardComponent",
        "gameVariableComponent",
        "buttonComponent",
        "textComponent",
        "richTextComponent",
        "inputComponent",
        "imageComponent",
        "helperComponent",
        "interactiveBoardSurface"
      ]
    },
    "interactiveBoardSurfaceProps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sceneId": {
          "type": "string",
          "minLength": 1
        },
        "designWidth": {
          "type": "integer",
          "minimum": 320,
          "maximum": 100000,
          "description": "Ширина логической координатной плоскости сцены, а не физического canvas или окна браузера. Клиент обязан ограничивать размер поверхности вывода независимо от этого значения.",
          "default": 1400
        },
        "designHeight": {
          "type": "integer",
          "minimum": 320,
          "maximum": 100000,
          "description": "Высота логической координатной плоскости сцены, а не физического canvas или окна браузера. Клиент обязан ограничивать размер поверхности вывода независимо от этого значения.",
          "default": 1000
        },
        "accessibleLabel": {
          "type": "string"
        },
        "interactions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "modeActionId": {
              "type": "string"
            },
            "selectActionId": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "sceneId"
      ]
    },
    "workspaceSlot": {
      "type": "string",
      "description": "Semantic placement owned by the generic map-first workspace. Games select a role; the player decides its physical position and stacking.",
      "enum": [
        "board",
        "status",
        "primary-panel",
        "context-panel",
        "action-tray",
        "floating-controls",
        "overlay"
      ]
    },
    "componentTreeContainsWorkspaceSlot": {
      "description": "Recursive detector used to forbid workspaceSlot outside direct map-first zones.",
      "anyOf": [
        {
          "type": "object",
          "required": ["props"],
          "properties": {
            "props": {
              "type": "object",
              "required": ["workspaceSlot"]
            }
          }
        },
        {
          "type": "object",
          "required": ["children"],
          "properties": {
            "children": {
              "type": "array",
              "contains": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
            }
          }
        }
      ]
    },
    "mapFirstWorkspaceZone": {
      "type": "object",
      "description": "A direct child of a map-first screen root. Nested children are ordinary components and cannot declare another workspace zone.",
      "required": ["type", "props"],
      "properties": {
        "type": { "const": "areaComponent" },
        "props": {
          "type": "object",
          "required": ["workspaceSlot"],
          "properties": {
            "workspaceSlot": { "$ref": "#/definitions/workspaceSlot" }
          }
        },
        "children": {
          "type": "array",
          "items": {
            "not": { "$ref": "#/definitions/componentTreeContainsWorkspaceSlot" }
          }
        }
      }
    },
    "uiComponent": {
      "type": "object",
      "description": "Описание UI-компонента в декларативном формате Hybrid SDUI.",
      "required": ["type"],
      "properties": {
        "type": {
          "anyOf": [
            { "$ref": "#/definitions/uiComponentType" },
            {
              "type": "string",
              "description": "Кастомный тип компонента (widget:*, extension:* или другой).",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_:-]*$"
            }
          ],
          "description": "Тип компонента: стандартный (screenComponent, buttonComponent и др.) или кастомный (widget:inventory, extension:rpg-stats)."
        },
        "id": {
          "type": "string",
          "description": "Optional stable identifier of this component instance."
        },
        "if": {
          "type": "string",
          "description": "Optional conditional rendering expression evaluated by the presenter."
        },
        "props": {
          "type": "object",
          "description": "Component-specific properties, may include data bindings like {{state.public.hp}}.",
          "properties": {
            "workspaceSlot": { "$ref": "#/definitions/workspaceSlot" }
          }
        },
        "style": {
          "$ref": "#/definitions/uiStyle"
        },
        "actions": {
          "$ref": "#/definitions/uiActions"
        },
        "layout_id": {
          "type": "string",
          "description": "Optional reference to a layout entry that describes visual design for this component. DEPRECATED: Use design_artifact_id."
        },
        "design_artifact_id": {
          "type": "string",
          "description": "ID дизайн-артефакта из секции design_artifacts.registry, описывающего визуальный дизайн этого компонента."
        },
        "controller_id": {
          "type": "string",
          "description": "Optional identifier of a UI-level controller in the UI library."
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/uiComponent" }
        },
        "designImageRef": {
          "type": "string"
        },
        "itemTemplate": {
          "$ref": "#/definitions/uiItemTemplate"
        },
        "visualMode": {
          "enum": [
            "image",
            "style",
            "auto"
          ],
          "type": "string"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": ["props"],
            "properties": {
              "props": {
                "type": "object",
                "required": ["workspaceSlot"]
              }
            }
          },
          "then": {
            "properties": {
              "type": { "const": "areaComponent" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "buttonComponent"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "type": "object",
                "required": [
                  "caption"
                ],
                "properties": {
                  "caption": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "richTextComponent"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "type": "object",
                "required": [
                  "html"
                ],
                "properties": {
                  "html": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "imageComponent"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "type": "object",
                "required": [
                  "src"
                ],
                "properties": {
                  "src": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "gameVariableComponent"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "type": "object",
                "anyOf": [
                  {
                    "required": ["metricId"],
                    "properties": {
                      "metricId": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "required": ["caption"],
                    "properties": {
                      "caption": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "required": ["value"],
                    "properties": {
                      "value": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "cardComponent"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "type": "object",
                "anyOf": [
                  {
                    "required": ["text"],
                    "properties": {
                      "text": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "required": ["title"],
                    "properties": {
                      "title": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "required": ["summary"],
                    "properties": {
                      "summary": { "type": "string", "minLength": 1 }
                    }
                  },
                  {
                    "required": ["backText"],
                    "properties": {
                      "backText": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "interactiveBoardSurface"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "props"
            ],
            "properties": {
              "props": {
                "$ref": "#/definitions/interactiveBoardSurfaceProps"
              }
            }
          }
        }
      ]
    },
    "uiItemTemplate": {
      "type": "object",
      "description": "Declarative collection iteration for manifest-rendered components.",
      "required": [
        "collection",
        "itemKey"
      ],
      "properties": {
        "collection": {
          "type": "string"
        },
        "filter": {
          "type": "string"
        },
        "itemKey": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "uiStyle": {
      "type": "object",
      "properties": {
        "width": { "type": ["string", "number"] },
        "height": { "type": ["string", "number"] },
        "padding": { "type": ["string", "number"] },
        "margin": { "type": ["string", "number"] },
        "background": { "type": "string" },
        "color": { "type": "string" },
        "fontSize": { "type": ["string", "number"] },
        "fontWeight": { "type": ["string", "number"] },
        "border": { "type": "string" },
        "borderRadius": { "type": ["string", "number"] },
        "gap": { "type": ["string", "number"] },
        "flex": { "type": ["integer", "string"] },
        "flexDirection": { "enum": ["row", "column", "row-reverse", "column-reverse"] },
        "justifyContent": { "type": "string" },
        "alignItems": { "type": "string" }
      },
      "additionalProperties": true
    },
    "uiActions": {
      "type": "object",
      "description": "UI-level event handlers mapping events like 'onClick' to Presenter commands or explicit runtime action requests.",
      "patternProperties": {
        "^on[A-Z][a-zA-Z]+$": {
          "type": "object",
          "required": ["command"],
          "properties": {
            "command": {
              "type": "string",
              "description": "Identifier of the command to send to the Presenter, for example showPanel, closePanel, advance or requestServer."
            },
            "payload": {
              "type": "object",
              "description": "Optional JSON payload with parameters for this invocation."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "designArtifactRef": {
      "type": "object",
      "description": "Ссылка на дизайн-артефакт в реестре design_artifacts. Использует паттерн source_ref из ADR-013.",
      "required": ["type", "source_ref"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Тип дизайн-артефакта.",
          "enum": ["reference", "concept", "flowchart", "wireframe", "storyboard", "mockup", "asset"]
        },
        "source_ref": {
          "type": "object",
          "description": "Ссылка на внешний файл с описанием артефакта.",
          "required": ["file"],
          "properties": {
            "file": {
              "type": "string",
              "description": "Относительный путь к файлу *.design.json от base_path."
            }
          },
          "additionalProperties": true
        },
        "target": {
          "type": "object",
          "description": "Опциональная связь с UI-элементом (экраном или компонентом).",
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["screen", "component"],
              "description": "Тип целевого элемента."
            },
            "id": {
              "type": "string",
              "description": "ID целевого экрана или компонента."
            }
          },
          "additionalProperties": true
        },
        "variant": {
          "type": "string",
          "description": "Опциональный вариант артефакта (desktop, mobile, dark-theme и др.)."
        },
        "meta": {
          "type": "object",
          "description": "Дополнительные метаданные.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
