{
  "$ref": "#/definitions/RootGameManifest",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "GameManifest": {
      "additionalProperties": false,
      "properties": {
        "actions": {
          "description": "Published Game Intent catalog. Its complete structure is validated by the separate JSON Schema 2020-12 contract.",
          "type": "object"
        },
        "config": {
          "$ref": "#/definitions/GameManifestConfig"
        },
        "content": {
          "$ref": "#/definitions/GameManifestContent"
        },
        "engine": {
          "$ref": "#/definitions/GameManifestEngineConfig"
        },
        "executionMode": {
          "$ref": "#/definitions/GameManifestExecutionMode"
        },
        "agentRuntime": {
          "$ref": "#/definitions/GameManifestAgentRuntimeConfig"
        },
        "meta": {
          "$ref": "#/definitions/GameManifestMeta"
        },
        "objectModels": {
          "$ref": "#/definitions/GameManifestObjectModelMap"
        },
        "networkModels": {
          "$ref": "#/definitions/GameManifestTransportNetworkModelMap"
        },
        "state": {
          "$ref": "#/definitions/GameManifestState%3Calias-942026824-74138-74264-942026824-0-218439%3Cstring%2Cunknown%3E%2Calias-942026824-74138-74264-942026824-0-218439%3Cstring%2Cunknown%3E%3E"
        },
        "mechanics": {
          "description": "Canonical Mechanics IR bundle. Its complete structure is validated by the separate JSON Schema 2020-12 contract.",
          "type": "object"
        }
      },
      "required": [
        "meta",
        "config",
        "state",
        "actions",
        "mechanics"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "executionMode": {
                "enum": [
                  "hybrid",
                  "ai-driven"
                ]
              }
            },
            "required": [
              "executionMode"
            ]
          },
          "then": {
            "required": [
              "agentRuntime"
            ],
            "properties": {
              "agentRuntime": {
                "type": "object",
                "required": [
                  "required"
                ],
                "properties": {
                  "required": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "agentRuntime": {
                "type": "object",
                "properties": {
                  "required": {
                    "const": true
                  }
                },
                "required": [
                  "required"
                ]
              }
            },
            "required": [
              "agentRuntime"
            ]
          },
          "then": {
            "required": [
              "executionMode"
            ],
            "properties": {
              "executionMode": {
                "enum": [
                  "hybrid",
                  "ai-driven"
                ]
              }
            }
          }
        }
      ],
      "type": "object"
    },
    "GameManifestSafeIdentifier": {
      "description": "Bounded identifier safe for use as an own object key or JSON Pointer segment.",
      "pattern": "^(?!(?:__proto__|constructor|prototype)$)[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "GameManifestCanonicalPoint": {
      "additionalProperties": false,
      "properties": {
        "x": {
          "maximum": 1000000000,
          "minimum": -1000000000,
          "type": "number"
        },
        "y": {
          "maximum": 1000000000,
          "minimum": -1000000000,
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "type": "object"
    },
    "GameManifestTransportRegion": {
      "additionalProperties": false,
      "description": "Bounded simple polygon. A final point equal to the first is an optional explicit closure and is not counted as an additional canonical vertex.",
      "properties": {
        "id": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "polygon": {
          "items": {
            "$ref": "#/definitions/GameManifestCanonicalPoint"
          },
          "maxItems": 513,
          "minItems": 3,
          "type": "array"
        }
      },
      "required": [
        "id",
        "polygon"
      ],
      "type": "object"
    },
    "GameManifestTransportRoadPortal": {
      "additionalProperties": false,
      "description": "One compiler-derived positive-length shared boundary between two transport regions.",
      "properties": {
        "id": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "regionIds": {
          "items": {
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array",
          "uniqueItems": true
        },
        "from": {
          "$ref": "#/definitions/GameManifestCanonicalPoint"
        },
        "to": {
          "$ref": "#/definitions/GameManifestCanonicalPoint"
        }
      },
      "required": [
        "id",
        "regionIds",
        "from",
        "to"
      ],
      "type": "object"
    },
    "GameManifestTransportRoadPlanning": {
      "additionalProperties": false,
      "description": "Explicit opt-in contract for authoritative minimum-region road planning. The navigation graph and hash are compiler-derived from canonical region polygons.",
      "properties": {
        "mode": {
          "const": "region-segment-minimum"
        },
        "algorithmVersion": {
          "const": "region-segment-minimum-v1"
        },
        "geometryVersion": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        },
        "geometryHash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "tieBreak": {
          "const": "session-random"
        },
        "boundaryPolicy": {
          "const": "lowest-region-id"
        },
        "excludedRegionIdsEndpoint": {
          "$ref": "#/definitions/GameManifestSafeIdentifier"
        },
        "navigationGraph": {
          "additionalProperties": false,
          "properties": {
            "portals": {
              "items": {
                "$ref": "#/definitions/GameManifestTransportRoadPortal"
              },
              "maxItems": 4096,
              "type": "array"
            }
          },
          "required": [
            "portals"
          ],
          "type": "object"
        }
      },
      "required": [
        "mode",
        "algorithmVersion",
        "geometryVersion",
        "geometryHash",
        "tieBreak",
        "boundaryPolicy",
        "navigationGraph"
      ],
      "type": "object"
    },
    "GameManifestTransportMovementModel": {
