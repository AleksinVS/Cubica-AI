          },
          "minItems": 1,
          "type": "array"
        },
        "traversableEdgeStates": {
          "items": {
            "$ref": "#/definitions/GameManifestObjectFacetValue"
          },
          "minItems": 1,
          "type": "array"
        },
        "capacityCollection": {
          "minLength": 1,
