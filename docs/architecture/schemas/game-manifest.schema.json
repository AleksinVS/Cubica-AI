        },
        "coupledCollection": {
          "minLength": 1,
          "type": "string"
        },
        "coupledObjectTypes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "coupledStateFacet": {
          "minLength": 1,
          "type": "string"
        },
        "couplableVehicleStates": {
          "items": {
            "$ref": "#/definitions/GameManifestObjectFacetValue"
          },
          "minItems": 1,
