        },
        "capacityObjectTypes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "capacityLocationAttribute": {
          "minLength": 1,
          "type": "string"
        },
        "capacityStateFacet": {
          "minLength": 1,
          "type": "string"
        },
        "capacityOccupyingStates": {
          "items": {
            "$ref": "#/definitions/GameManifestObjectFacetValue"
          },
          "minItems": 1,
          "type": "array"
        },
        "maxVehiclesPerNode": {
          "minimum": 1,
