{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cubica.local/schemas/external-skill-memory.schema.json",
  "title": "Cubica External Skill Adaptation Memory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "revision", "entries"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "revision": { "type": "integer", "minimum": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "recordedOn", "status", "title", "tags", "symptom", "cause", "guidance", "ruleIds", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^EXP-[0-9]{4}$" },
          "recordedOn": { "type": "string", "format": "date" },
          "status": { "enum": ["active", "superseded"] },
          "title": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "symptom": { "type": "string", "minLength": 1 },
          "cause": { "type": "string", "minLength": 1 },
          "guidance": { "type": "string", "minLength": 1 },
          "ruleIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    }
  }
}
