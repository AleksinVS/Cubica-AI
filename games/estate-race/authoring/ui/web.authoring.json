{
  "$schema": "../../../../docs/architecture/schemas/ui-authoring-v2.schema.json",
  "_schemaVersion": "2.0",
  "_manifestType": "ui",
  "_channel": "web",
  "_definitions": {},
  "root": {
    "_type": "ui.Manifest",
    "_label": "Web-интерфейс: Estate Race · прототип",
    "_semantics": "Корневая сущность UI authoring v2.",
    "meta": {
      "id": "estate-race.ui.web",
      "version": "0.1.0",
      "schema_version": "1.0",
      "game_id": "estate-race",
      "game_manifest_version": "0.1.0",
      "channel": "web",
      "author": "Cubica"
    },
    "entry_point": "table",
    "screen_routing": [
      {
        "screenKey": "table",
        "conditions": {
          "screenId": "table",
          "layoutMode": "topbar"
        }
      }
    ],
    "screens": [
      {
        "id": "table",
        "_type": "ui.Screen",
        "_label": "Экран table: Estate Race · прототип",
        "_semantics": "Экран UI-манифеста table.",
        "title": "Estate Race · прототип",
        "layout_mode": "topbar",
        "root": {
          "_type": "ui.Component",
          "_label": "Корневой контейнер table root",
          "_semantics": "UI-компонент типа screenComponent.",
          "id": "table.root",
          "type": "screenComponent",
          "props": {
            "cssClass": "board-game-shell"
          },
          "children": [
            {
              "_type": "ui.Component",
              "_label": "Область table header",
              "_semantics": "UI-компонент типа areaComponent.",
              "id": "table.header",
              "type": "areaComponent",
              "props": {
                "cssClass": "board-game-header"
              },
              "children": [
                {
                  "_type": "ui.Component",
                  "_label": "Estate Race · прототип Ход · активен · этап",
                  "_semantics": "UI-компонент типа richTextComponent.",
                  "id": "table.title",
                  "type": "richTextComponent",
                  "props": {
                    "html": "<h1>Estate Race · прототип</h1><p>Ход {{game.state.public.turn.turnNumber}} · активен {{game.state.public.turn.activePlayerId}} · этап {{game.state.public.turn.phase}}</p>"
                  }
                }
              ]
            },
            {
              "_type": "ui.Component",
              "_label": "Область table players",
              "_semantics": "UI-компонент типа areaComponent.",
              "id": "table.players",
              "type": "areaComponent",
              "props": {
                "cssClass": "board-game-players"
              },
              "children": [
                {
                  "_type": "ui.Component",
                  "_label": "Игрок 1 монет · клетка",
                  "_semantics": "UI-компонент типа richTextComponent.",
                  "id": "table.player-one",
                  "type": "richTextComponent",
                  "props": {
                    "html": "<h2>Игрок 1</h2><p>{{game.state.players.p1.metrics.cash}} монет · клетка {{game.state.players.p1.metrics.position}}</p>"
                  }
                },
                {
                  "_type": "ui.Component",
                  "_label": "Игрок 2 монет · клетка",
                  "_semantics": "UI-компонент типа richTextComponent.",
                  "id": "table.player-two",
                  "type": "richTextComponent",
                  "props": {
                    "html": "<h2>Игрок 2</h2><p>{{game.state.players.p2.metrics.cash}} монет · клетка {{game.state.players.p2.metrics.position}}</p>"
                  }
                }
              ]
            },
            {
              "_type": "ui.Component",
              "_label": "Область table workspace",
              "_semantics": "UI-компонент типа areaComponent.",
              "id": "table.workspace",
              "type": "areaComponent",
              "props": {
                "cssClass": "board-game-workspace"
              },
              "children": [
                {
                  "_type": "ui.Component",
                  "_label": "Компонент table board",
                  "_semantics": "UI-компонент типа interactiveBoardSurface.",
                  "id": "table.board",
                  "type": "interactiveBoardSurface",
                  "props": {
                    "sceneId": "main",
                    "designWidth": 1400,
                    "designHeight": 1000,
                    "accessibleLabel": "Игровое поле Estate Race"
                  }
                }
              ]
            },
            {
              "_type": "ui.Component",
              "_label": "Последний бросок: · сумма",
              "_semantics": "UI-компонент типа richTextComponent.",
              "id": "table.roll",
              "type": "richTextComponent",
              "props": {
                "cssClass": "board-game-roll",
                "html": "<p><strong>Последний бросок:</strong> {{game.state.public.board.lastRoll.values}} · сумма {{game.state.public.board.lastRoll.total}}</p>"
              }
            },
            {
              "_type": "ui.Component",
              "_label": "Краткий журнал хода",
              "_semantics": "Показывает подтверждённые Runtime API записи, не вычисляя правила в интерфейсе.",
              "id": "table.log",
              "type": "areaComponent",
              "props": {
                "cssClass": "board-game-log"
              },
              "children": [
                {
                  "_type": "ui.Component",
                  "_label": "Заголовок журнала",
                  "_semantics": "Коротко обозначает подтверждённую историю действий.",
                  "id": "table.log-title",
                  "type": "richTextComponent",
                  "props": {
                    "html": "<h2>Журнал</h2>"
                  }
                },
                {
                  "_type": "ui.Component",
                  "_label": "Записи журнала",
                  "_semantics": "Повторяет публичные записи журнала в порядке Runtime API.",
                  "id": "table.log-entries",
                  "type": "areaComponent",
                  "props": {
                    "cssClass": "board-game-log-entries"
                  },
                  "itemTemplate": {
                    "collection": "{{game.state.public.log}}",
                    "itemKey": "logEntry"
                  },
                  "children": [
                    {
                      "_type": "ui.Component",
                      "_label": "Запись журнала",
                      "_semantics": "Показывает авторское описание либо идентификатор подтверждённого действия.",
                      "id": "table.log-entry",
                      "type": "richTextComponent",
                      "props": {
                        "html": "<p><strong>{{logEntry.kind}}</strong> {{logEntry.summary}}</p>"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
