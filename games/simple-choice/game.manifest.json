{
  "meta": {
    "id": "simple-choice",
    "version": "1.0.0",
    "name": "Simple Choice",
    "description": "Minimal manifest-driven game used as a second-game architecture fixture.",
    "author": "Cubica",
    "schemaVersion": "1.1",
    "minEngineVersion": "0.1.0",
    "training": {
      "format": "single",
      "duration": {
        "minMinutes": 1,
        "maxMinutes": 3
      },
      "competencies": [
        {
          "id": "decision-making",
          "name": "Decision Making",
          "description": "Makes a single explicit choice and observes the result."
        }
      ]
    }
  },
  "config": {
    "players": {
      "min": 1,
      "max": 1
    },
    "settings": {
      "mode": "singleplayer",
      "locale": "en-US"
    }
  },
  "content": {
    "data": {
      "choices": [
        {
          "id": "accept",
          "title": "Take the clear path",
          "summary": "Choose the option with the visible tradeoff.",
          "backText": "The choice is resolved and the session gained a supply token.",
          "actionId": "choice.accept"
        }
      ]
    }
  },
  "objectModels": {
    "choice.card": {
      "collection": "choices",
      "scope": "session",
      "facets": {
        "face": {
          "initial": "front",
          "values": [
            "front",
            "back"
          ]
        },
        "availability": {
          "initial": "available",
          "values": [
            "available",
            "locked",
            "hidden"
          ]
        }
      },
      "idField": "id",
      "view": {
        "facets": {
          "face.front": {
            "summaryFrom": "summary",
            "visualState": "default"
          },
          "face.back": {
            "summaryFrom": "backText",
            "visualState": "resolved"
          },
          "availability.available": {
            "visible": true,
            "interactive": true
          },
          "availability.locked": {
            "visualState": "locked",
            "visible": true,
            "interactive": false
          },
          "availability.hidden": {
            "visible": false
          }
        }
      }
    },
    "resource.supply": {
      "collection": "resources",
      "scope": "session",
      "facets": {
        "availability": {
          "initial": "available",
          "values": [
            "available",
            "spent"
          ]
        }
      },
      "idField": "id",
      "view": {
        "facets": {
          "availability.available": {
            "summaryFrom": "title",
            "visualState": "default",
            "visible": true,
            "interactive": false
          },
          "availability.spent": {
            "summaryFrom": "title",
            "visualState": "locked",
            "visible": true,
            "interactive": false
          }
        }
      }
    }
  },
  "engine": {
    "systemPrompt": "Run the simple choice game deterministically from the manifest."
  },
  "state": {
    "public": {
      "timeline": {
        "line": "main",
        "stepIndex": 0,
        "step_index": 0,
        "stageId": "stage_simple",
        "stage_id": "stage_simple",
        "screenId": "intro",
        "screen_id": "intro",
        "canAdvance": false
      },
      "metrics": {
        "score": 0
      },
      "choice": {
        "outcome": "pending"
      },
      "flags": {
        "cards": {}
      },
      "objects": {
        "choices": {
          "accept": {
            "objectType": "choice.card",
            "facets": {
              "face": "front",
              "availability": "available"
            },
            "attributes": {}
          }
        },
        "resources": {}
      },
      "ui": {},
      "log": []
    },
    "secret": {}
  },
  "actions": {
    "choice.accept": {
      "handlerType": "manifest-data",
      "capabilityFamily": "runtime.server",
      "capability": "simple-choice.choice.accept",
      "displayName": "Accept the choice",
      "deterministic": {
        "guard": {
          "timeline": {
            "line": "main",
            "stepIndex": 0,
            "canAdvance": false
          },
          "object": {
            "visibility": "public",
            "collection": "choices",
            "objectId": "accept",
            "objectType": "choice.card",
            "facets": {
              "face": "front",
              "availability": "available"
            }
          }
        },
        "effects": [
          {
            "op": "metric.add",
            "metricId": "score",
            "delta": 1
          },
          {
            "op": "object.state.set",
            "visibility": "public",
            "collection": "choices",
            "objectId": "accept",
            "facet": "face",
            "value": "back"
          },
          {
            "op": "object.attribute.patch",
            "visibility": "public",
            "collection": "choices",
            "objectId": "accept",
            "patches": [
              {
                "op": "replace",
                "path": "/selectedAtStep",
                "value": 0
              }
            ]
          },
          {
            "op": "object.create",
            "visibility": "public",
            "collection": "resources",
            "objectId": "supply-1",
            "objectType": "resource.supply",
            "facets": {
              "availability": "available"
            },
            "attributes": {
              "id": "supply-1",
              "title": "Supply token",
              "amount": 1
            }
          },
          {
            "op": "timeline.set",
            "canAdvance": false,
            "stepIndex": 1,
            "screenId": "result",
            "activeInfoId": "result"
          },
          {
            "op": "state.patch",
            "patches": [
              {
                "op": "replace",
                "path": "/public/choice/outcome",
                "value": "accepted"
              }
            ]
          },
          {
            "op": "log.append",
            "kind": "choice-resolution",
            "entityType": "choice",
            "displayMode": "summary",
            "summary": "The player chose the clear path.",
            "auditMetrics": true
          }
        ]
      }
    }
  }
}
