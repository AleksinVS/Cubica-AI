{
  "meta": {
    "id": "simple-choice.ui.web",
    "version": "1.0.0",
    "game_id": "simple-choice"
  },
  "entry_point": "intro",
  "metric_specs": [
    {
      "id": "score",
      "caption": "Score",
      "value": "{{game.state.public.metrics.score}}",
      "aliases": [
        "score"
      ],
      "layout": "prominent"
    }
  ],
  "screen_routing": [
    {
      "screenKey": "intro",
      "conditions": {
        "screenId": "intro",
        "layoutMode": "topbar"
      }
    },
    {
      "screenKey": "result",
      "conditions": {
        "screenId": "result",
        "layoutMode": "topbar"
      }
    }
  ],
  "screens": {
    "intro": {
      "title": "Simple Choice",
      "layout_mode": "topbar",
      "root": {
        "type": "screenComponent",
        "props": {
          "cssClass": "topbar-screen-shell",
          "backgroundImage": "/images/arctic-background.png"
        },
        "children": [
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "topbar-metrics"
            },
            "children": [
              {
                "type": "gameVariableComponent",
                "id": "score",
                "props": {
                  "caption": "Score",
                  "value": "{{game.state.public.metrics.score}}"
                }
              }
            ]
          },
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "info-main-content"
            },
            "children": [
              {
                "type": "richTextComponent",
                "id": "intro-text",
                "props": {
                  "html": "<h1>Simple Choice</h1><p>Pick the clear option to prove the generic player path.</p>"
                }
              },
              {
                "type": "buttonComponent",
                "id": "choice-accept",
                "props": {
                  "caption": "Choose path",
                  "variant": "action"
                },
                "actions": {
                  "onClick": {
                    "command": "requestServer",
                    "payload": {
                      "actionId": "choice.accept"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    },
    "result": {
      "title": "Simple Choice Result",
      "layout_mode": "topbar",
      "root": {
        "type": "screenComponent",
        "props": {
          "cssClass": "topbar-screen-shell",
          "backgroundImage": "/images/arctic-background.png"
        },
        "children": [
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "topbar-metrics"
            },
            "children": [
              {
                "type": "gameVariableComponent",
                "id": "score",
                "props": {
                  "caption": "Score",
                  "value": "{{game.state.public.metrics.score}}"
                }
              }
            ]
          },
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "info-main-content"
            },
            "children": [
              {
                "type": "richTextComponent",
                "id": "result-text",
                "props": {
                  "html": "<h1>Result</h1><p>Outcome: {{game.state.public.choice.outcome}}</p>"
                }
              }
            ]
          }
        ]
      }
    }
  }
}
