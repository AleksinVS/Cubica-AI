      "plans": {
        "choice.accept": {
          "transaction": {
            "steps": [
              {
                "id": "s001-precondition",
                "kind": "assert",
                "op": "core.assert",
                "predicate": {
                  "op": "predicate.all",
                  "items": [
                    {
                      "op": "predicate.compare",
                      "operator": "eq",
                      "left": {
                        "op": "value.state",
                        "ref": {
                          "endpoint": "public.timeline.line"
                        }
                      },
                      "right": {
                        "op": "value.literal",
                        "value": "main"
                      }
                    },
                    {
                      "op": "predicate.compare",
                      "operator": "eq",
                      "left": {
                        "op": "value.state",
                        "ref": {
                          "endpoint": "public.timeline.stepIndex"
                        }
                      },
                      "right": {
                        "op": "value.literal",
                        "value": 0
                      }
                    },
                    {
                      "op": "predicate.compare",
                      "operator": "eq",
                      "left": {
                        "op": "value.state",
                        "ref": {
                          "endpoint": "public.timeline.canAdvance"
                        }
                      },
                      "right": {
                        "op": "value.literal",
                        "value": false
                      }
                    },
                    {
                      "op": "predicate.entity.matches",
                      "entity": {
                        "collection": "choices",
                        "entityId": {
                          "op": "value.literal",
                          "value": "accept"
                        }
                      },
                      "objectType": "choice.card",
                      "facets": {
                        "face": {
                          "op": "value.literal",
                          "value": "front"
                        },
                        "availability": {
                          "op": "value.literal",
                          "value": "available"
                        }
                      }
                    }
                  ]
                },
                "errorCode": "ACTION_PRECONDITION_FAILED"
              },
              {
                "id": "s002",
                "kind": "command",
                "op": "core.number.add",
                "target": {
                  "endpoint": "public.metrics.score"
                },
                "delta": {
                  "op": "value.literal",
                  "value": 1
                }
              },
              {
                "id": "s003",
                "kind": "command",
                "op": "core.entity.facet.set",
                "entity": {
                  "collection": "choices",
                  "entityId": {
                    "op": "value.literal",
                    "value": "accept"
                  }
                },
                "facet": "face",
                "value": {
