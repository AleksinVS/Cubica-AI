{
  "$schema": "../../../docs/architecture/schemas/game-authoring-v2.schema.json",
  "_schemaVersion": "2.0",
  "_manifestType": "game",
  "_definitions": {},
  "root": {
    "_type": "game.Game",
    "_label": "Игра Simple Choice",
    "_semantics": "Minimal manifest-driven game used as a second-game architecture fixture.",
    "meta": {
      "id": "simple-choice",
      "version": "1.0.0",
      "name": "Simple Choice",
      "description": "Minimal manifest-driven game used as a second-game architecture fixture.",
      "author": "Cubica",
      "schemaVersion": "1.1",
      "minEngineVersion": "0.1.0",
      "training": {
        "format": "single",
        "duration": {
          "minMinutes": 1,
          "maxMinutes": 3
        },
        "competencies": [
          {
            "id": "decision-making",
            "name": "Decision Making",
            "description": "Makes a single explicit choice and observes the result."
          }
        ]
      }
    },
    "config": {
      "players": {
        "min": 1,
        "max": 1
      },
      "settings": {
        "mode": "singleplayer",
        "locale": "en-US"
      }
    },
    "content": {
      "data": {
        "choices": [
          {
            "_type": "game.Choice",
            "_label": "Take the clear path",
            "_semantics": "Сущность игрового контента из коллекции choices.",
            "id": "accept",
            "title": "Take the clear path",
            "summary": "Choose the option with the visible tradeoff.",
            "backText": "The choice is resolved and the session gained a supply token.",
            "actionId": "choice.accept"
          }
        ]
      }
    },
    "objectTypes": {
      "choice.card": {
        "_type": "game.ObjectType",
        "_label": "Choice card object state",
        "_semantics": "Generic object state model for a selectable choice card.",
        "collection": "choices",
        "idField": "id",
        "scope": "session",
        "facets": {
          "face": {
            "initial": "front",
            "values": {
              "front": {
                "view": {
                  "summaryFrom": "summary",
                  "visualState": "default"
                }
              },
              "back": {
                "view": {
                  "summaryFrom": "backText",
                  "visualState": "resolved"
                }
              }
            }
          },
          "availability": {
            "initial": "available",
            "values": {
              "available": {
                "interactive": true,
                "visible": true
              },
              "locked": {
                "interactive": false,
                "visible": true,
                "view": {
                  "visualState": "locked"
                }
              },
              "hidden": {
                "visible": false
              }
            }
          }
        }
      },
      "resource.supply": {
        "_type": "game.ObjectType",
        "_label": "Supply resource object state",
        "_semantics": "Generic dynamic resource object created during a game session.",
        "collection": "resources",
        "idField": "id",
        "scope": "session",
        "facets": {
          "availability": {
            "initial": "available",
            "values": {
              "available": {
                "interactive": false,
                "visible": true,
                "view": {
                  "summaryFrom": "title",
                  "visualState": "default"
                }
              },
              "spent": {
                "interactive": false,
                "visible": true,
                "view": {
                  "summaryFrom": "title",
                  "visualState": "locked"
                }
              }
            }
          }
        }
      }
    },
    "engine": {
      "systemPrompt": "Run the simple choice game deterministically from the manifest."
    },
    "state": {
      "public": {
        "timeline": {
          "line": "main",
          "stepIndex": 0,
          "step_index": 0,
          "stageId": "stage_simple",
          "stage_id": "stage_simple",
          "screenId": "intro",
          "screen_id": "intro",
          "canAdvance": false
        },
        "metrics": {
          "score": 0
        },
        "choice": {
          "outcome": "pending"
        },
        "flags": {
          "cards": {}
        },
        "objects": {
          "choices": {
            "accept": {
              "objectType": "choice.card",
              "facets": {
                "face": "front",
                "availability": "available"
              },
              "attributes": {}
            }
          },
          "resources": {}
        },
        "ui": {},
        "log": []
      },
      "secret": {}
    },
    "logic": {
      "_type": "game.Logic",
      "_label": "Логика игры",
      "_semantics": "Сценарные потоки, правила и действия authoring-манифеста.",
      "flows": [
        {
          "id": "main",
          "_type": "game.Flow",
          "_label": "Основной поток",
          "_semantics": "Минимальный поток для игры без явной коллекции сценарных шагов.",
          "pattern": "pearl-string",
          "steps": [
            {
              "id": "main.start",
              "_type": "game.Step",
              "_label": "Начальное состояние",
              "_semantics": "Начальный шаг, восстановленный из runtime state.",
              "screenId": "intro",
              "actionIds": [
                "choice.accept"
              ]
            }
          ]
        }
      ],
      "systems": [],
      "rules": [],
      "actions": [
        {
          "id": "choice.accept",
          "_type": "game.Action",
          "_label": "Действие: Take the clear path",
          "_semantics": "Игровое действие choice.accept.",
          "handlerType": "manifest-data",
          "capabilityFamily": "runtime.server",
          "capability": "simple-choice.choice.accept",
          "displayName": "Accept the choice",
          "deterministic": {
            "guard": {
              "timeline": {
                "line": "main",
                "stepIndex": 0,
                "canAdvance": false
              },
              "object": {
                "visibility": "public",
                "collection": "choices",
                "objectId": "accept",
                "objectType": "choice.card",
                "facets": {
                  "face": "front",
                  "availability": "available"
                }
              }
            },
            "effects": [
              {
                "op": "metric.add",
                "metricId": "score",
                "delta": 1
              },
              {
                "op": "object.state.set",
                "visibility": "public",
                "collection": "choices",
                "objectId": "accept",
                "facet": "face",
                "value": "back"
              },
              {
                "op": "object.attribute.patch",
                "visibility": "public",
                "collection": "choices",
                "objectId": "accept",
                "patches": [
                  {
                    "op": "replace",
                    "path": "/selectedAtStep",
                    "value": 0
                  }
                ]
              },
              {
                "op": "object.create",
                "visibility": "public",
                "collection": "resources",
                "objectId": "supply-1",
                "objectType": "resource.supply",
                "facets": {
                  "availability": "available"
                },
                "attributes": {
                  "id": "supply-1",
                  "title": "Supply token",
                  "amount": 1
                }
              },
              {
                "op": "timeline.set",
                "canAdvance": false,
                "stepIndex": 1,
                "screenId": "result",
                "activeInfoId": "result"
              },
              {
                "op": "state.patch",
                "patches": [
                  {
                    "op": "replace",
                    "path": "/public/choice/outcome",
                    "value": "accepted"
                  }
                ]
              },
              {
                "op": "log.append",
                "kind": "choice-resolution",
                "entityType": "choice",
                "displayMode": "summary",
                "summary": "The player chose the clear path.",
                "auditMetrics": true
              }
            ]
          }
        }
      ]
    }
  }
}
