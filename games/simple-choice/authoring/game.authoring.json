                "id": "s004",
                "kind": "command",
                "op": "core.entity.attributes.patch",
                "entity": {
                  "collection": "choices",
                  "entityId": {
                    "op": "value.literal",
                    "value": "accept"
                  }
                },
                "patches": [
                  {
                    "operation": "set",
                    "path": [
                      "selectedAtStep"
                    ],
                    "value": {
                      "op": "value.literal",
                      "value": 0
                    }
                  }
                ]
              },
              {
                "id": "s005",
                "kind": "command",
                "op": "core.entity.create",
                "visibility": "public",
                "collection": "resources",
                "entityId": {
                  "op": "value.literal",
                  "value": "supply-1"
                },
                "objectType": "resource.supply",
                "facets": {
                  "availability": {
                    "op": "value.literal",
                    "value": "available"
                  }
                },
                "attributes": {
                  "id": {
                    "op": "value.literal",
                    "value": "supply-1"
                  },
                  "title": {
                    "op": "value.literal",
                    "value": "Supply token"
                  },
                  "amount": {
                    "op": "value.literal",
                    "value": 1
                  }
                }
              },
              {
                "id": "s006",
                "kind": "command",
                "op": "core.state.patch",
                "patches": [
                  {
                    "operation": "set",
                    "target": {
                      "endpoint": "public.timeline.canAdvance"
                    },
                    "value": {
                      "op": "value.literal",
                      "value": false
                    }
                  },
                  {
                    "operation": "set",
                    "target": {
                      "endpoint": "public.timeline.stepIndex"
                    },
                    "value": {
                      "op": "value.literal",
                      "value": 1
                    }
                  },
                  {
                    "operation": "set",
                    "target": {
                      "endpoint": "public.timeline.step_index"
                    },
                    "value": {
                      "op": "value.literal",
                      "value": 1
                    }
                  },
                  {
                    "operation": "set",
                    "target": {
                      "endpoint": "public.timeline.screenId"
                    },
                    "value": {
                      "op": "value.literal",
