  "screens": {
    "S1": {
      "type": "screen",
      "layout_mode": "topbar",
      "root": {
        "type": "screenComponent",
        "props": {
          "backgroundImage": "/images/arctic-background.png",
          "cssClass": "main-screen topbar-screen-shell"
        },
        "children": [
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "game-variables-container topbar-variables-container"
            },
            "children": [
              {
                "type": "gameVariableComponent",
                "id": "remainingDays",
                "props": {
                  "metricId": "remainingDays",
                  "backgroundImage": "/images/top-sidebar/days-top.png",
                  "layout": "prominent"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "pro",
                "props": {
                  "metricId": "pro",
                  "backgroundImage": "/images/top-sidebar/znaniya.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "rep",
                "props": {
                  "metricId": "rep",
                  "backgroundImage": "/images/top-sidebar/doverie.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "lid",
                "props": {
                  "metricId": "lid",
                  "backgroundImage": "/images/top-sidebar/energia.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "man",
                "props": {
                  "metricId": "man",
                  "backgroundImage": "/images/top-sidebar/kontrol.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "stat",
                "props": {
                  "metricId": "stat",
                  "backgroundImage": "/images/top-sidebar/status.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "cont",
                "props": {
                  "metricId": "cont",
                  "backgroundImage": "/images/top-sidebar/kontakt.png"
                }
              },
              {
                "type": "gameVariableComponent",
                "id": "constr",
                "props": {
                  "metricId": "constr",
                  "backgroundImage": "/images/top-sidebar/konstruktiv.png"
                }
              },
              {
                "type": "areaComponent",
                "props": {
                  "cssClass": "sidebar-decoration"
                }
              }
            ]
          },
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "main-content-area topbar-main-content"
            },
            "children": [
              {
                "type": "areaComponent",
                "props": {
                  "cssClass": "cards-container topbar-cards-container"
                },
                "children": [
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-1",
                    "props": {
                      "text": "Антарктика — это огромный мир, скрытый под толщей льда. Мы живем здесь тысячелетиями, но мир меняется."
                    }
                  },
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-2",
                    "props": {
                      "text": "Наши предки оставили нам легенды об устойчивости айсберга, но Федор заметил неладное. Трещина растет."
                    }
                  },
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-3",
                    "props": {
                      "text": "Совет пингвинов пока спорит, но время уходит. Нужно действовать быстро, пока лед не тронулся."
                    }
                  },
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-4",
                    "props": {
                      "text": "Мы можем попытаться укрепить наш дом, но Профессор считает, что это лишь отсрочит неизбежное."
                    }
                  },
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-5",
                    "props": {
                      "text": "Слухи о чайках и новых землях кажутся сказкой, но что если это наш единственный шанс на спасение?"
                    }
                  },
                  {
                    "type": "cardComponent",
                    "actions": {
                      "onClick": {
                        "command": "requestServer",
                        "payload": {}
                      }
                    },
                    "id": "card-6",
                    "props": {
                      "text": "Каждый пингвин должен сделать выбор. Остаться и верить в чудо, или отправиться в неизвестность."
                    }
                  }
                ]
              },
              {
                "type": "areaComponent",
                "props": {
                  "cssClass": "bottom-controls-container"
                },
                "children": [
                  {
                    "type": "buttonComponent",
                    "props": {
                      "variant": "helper",
                      "caption": "Журнал ходов"
                    },
                    "actions": {
                      "onClick": {
                        "command": "showPanel",
                        "payload": {
                          "panelId": "history"
                        }
                      }
                    },
                    "id": "btn-journal"
                  },
                  {
                    "type": "buttonComponent",
                    "props": {
                      "variant": "helper",
                      "caption": "Подсказка"
                    },
                    "actions": {
                      "onClick": {
                        "command": "showPanel",
                        "payload": {
                          "panelId": "hint"
                        }
                      }
                    },
                    "id": "btn-hint"
                  },
                  {
                    "type": "buttonComponent",
                    "props": {
                      "variant": "nav",
                      "caption": "Назад"
                    },
                    "id": "nav-left"
                  },
                  {
                    "type": "buttonComponent",
                    "props": {
                      "variant": "nav",
                      "caption": "Вперед"
                    },
                    "id": "nav-right"
                  }
                ]
              }
            ]
          },
          {
            "type": "areaComponent",
            "props": {
              "cssClass": "additional-background"
            }
          }
        ]
      },
      "title": "Antarctica",
      "layout_id": "layout.web.s1"
    },
